# ──────────────────────────────────────────────────────────────────────────────
# ~/.zshrc — macOS Tool Collection template
# Generated by install.sh — do not edit manually if you want to re-run install
# ──────────────────────────────────────────────────────────────────────────────

# Enable Powerlevel10k instant prompt. Must stay near the top.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# ── OH MY ZSH ─────────────────────────────────────────────────────────────────

export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="powerlevel10k/powerlevel10k"

plugins=(
    git
    zsh-autosuggestions
    zsh-syntax-highlighting
)

source $ZSH/oh-my-zsh.sh

# ── PATH ──────────────────────────────────────────────────────────────────────

# macOS Tools (sbox, npkg, etool, ...)
export PATH="$HOME/.local/bin:$PATH"

# Antigravity
[[ -d "$HOME/.antigravity/antigravity/bin" ]] && export PATH="$HOME/.antigravity/antigravity/bin:$PATH"

# Antigravity IDE
[[ -d "$HOME/.antigravity-ide/antigravity-ide/bin" ]] && export PATH="$HOME/.antigravity-ide/antigravity-ide/bin:$PATH"

# Python 3.14
[[ -d "/Library/Frameworks/Python.framework/Versions/3.14/bin" ]] && \
    export PATH="/Library/Frameworks/Python.framework/Versions/3.14/bin:${PATH}"

# Android Platform Tools
[[ -d "$HOME/Documents/development/platform-tools" ]] && \
    export PATH="$PATH:$HOME/Documents/development/platform-tools"

# PlatformIO
[[ -d "$HOME/.platformio/penv/bin" ]] && export PATH="$PATH:$HOME/.platformio/penv/bin"

# Flutter
[[ -d "$HOME/Documents/development/flutter/bin" ]] && \
    export PATH="$PATH:$HOME/Documents/development/flutter/bin"

# Java (Homebrew openjdk@17)
if [[ -d "/opt/homebrew/opt/openjdk@17" ]]; then
    export JAVA_HOME="/opt/homebrew/opt/openjdk@17/libexec/openjdk.jdk/Contents/Home"
    export PATH="/opt/homebrew/opt/openjdk@17/bin:$PATH"
fi

# ── NVM ───────────────────────────────────────────────────────────────────────

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ]          && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# ── ALIASES ───────────────────────────────────────────────────────────────────

alias skills="open ~/.gemini/antigravity/skills"
alias map="open ~/.gemini/antigravity/mcp_config.json"

# ── FUNCTIONS ─────────────────────────────────────────────────────────────────

# VS Code CLI wrapper
code() {
  "/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code" "$@"
}

# Sandbox shell prompt indicator (set by sbox on launch)
if [ -n "$SB_NAME" ]; then
    export PROMPT="%F{yellow}[SANDBOX:$SB_NAME]%f $PROMPT"
fi

# Run Claude Code with DeepSeek API (MG-Cafe stack)
function claude-ds() {
    source ~/.config/mg-deepseek/key.env
    if [ "$DEEPSEEK_API_KEY" = "sk-your-key-here" ] || [ -z "$DEEPSEEK_API_KEY" ]; then
        echo "Error: Please set your actual DEEPSEEK_API_KEY in ~/.config/mg-deepseek/key.env"
        return 1
    fi

    local selected_model="deepseek-v4-pro"

    if [ "$1" = "flash" ]; then
        selected_model="deepseek-v4-flash"
        shift
    elif [ "$1" = "pro" ]; then
        selected_model="deepseek-v4-pro"
        shift
    fi

    cat > ~/.config/mg-deepseek/claude-deepseek-settings.json <<EOF
{
  "env": {
    "CLAUDE_CODE_USE_VERTEX": "",
    "ANTHROPIC_VERTEX_PROJECT_ID": "",
    "CLOUD_ML_REGION": "",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "",
    "ANTHROPIC_BASE_URL": "https://api.deepseek.com/anthropic",
    "ANTHROPIC_AUTH_TOKEN": "$DEEPSEEK_API_KEY",
    "ANTHROPIC_API_KEY": "$DEEPSEEK_API_KEY"
  }
}
EOF
    chmod 600 ~/.config/mg-deepseek/claude-deepseek-settings.json

    claude --bare \
        --settings ~/.config/mg-deepseek/claude-deepseek-settings.json \
        --model "$selected_model" \
        --system-prompt-file ~/.claude/skills/task-router/SKILL.md \
        --dangerously-skip-permissions "$@"
}

# ── GOOGLE CLOUD SDK ──────────────────────────────────────────────────────────

[[ -f "$HOME/Downloads/google-cloud-sdk/path.zsh.inc" ]] && \
    source "$HOME/Downloads/google-cloud-sdk/path.zsh.inc"
[[ -f "$HOME/Downloads/google-cloud-sdk/completion.zsh.inc" ]] && \
    source "$HOME/Downloads/google-cloud-sdk/completion.zsh.inc"

# ── POWERLEVEL10K ─────────────────────────────────────────────────────────────

[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
